{
  "expo": {
    "name": "Welist",
    "slug": "wilist",
    "owner": "vigosan",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wilist",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "io.wilist.app",
      "supportsTablet": true,
      "associatedDomains": ["applinks:wilist.io", "applinks:wilist.io"],
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "io.wilist.app",
      "adaptiveIcon": {
        "backgroundColor": "#0c0c0b",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "welist.io",
              "pathPrefix": "/lists/"
            },
            {
              "scheme": "https",
              "host": "welist.io",
              "pathPrefix": "/explore/"
            },
            {
              "scheme": "https",
              "host": "welist.io",
              "pathPrefix": "/u/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.3382559471-q1bdc5ov3ekjt3ungri7l7jaffi5f94p"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0c0b",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0c0c0b"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "90e514a5-f5d0-4c1f-aa05-fda9c93f317c"
      }
    }
  }
}
