{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    {
      "source": "/explore/:listId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|Discordbot|TelegramBot|Pinterest|redditbot|Googlebot|bingbot|Applebot|vkShare|SkypeUriPreview).*"
        }
      ],
      "destination": "/api/share/:listId"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "crons": [
    { "path": "/api/cron/random-item-nudge", "schedule": "0 9 1,15 * *" },
    { "path": "/api/cron/streak-at-risk", "schedule": "0 18 * * *" }
  ]
}
